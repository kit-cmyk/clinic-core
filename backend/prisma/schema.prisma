// ClinicCore 2.0 — Prisma Schema
// Multi-tenant: every tenant-scoped table carries tenant_id as an indexed FK.
// Architecture decision: tenant isolation via tenant_id column (not schema-per-tenant).
// See: CC Session Memory — Architecture Decisions #1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // Transaction pooler — used at runtime (port 6543)
  directUrl = env("DIRECT_URL")     // Direct connection — used by `prisma migrate` (port 5432)
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  DOCTOR
  NURSE
  SECRETARY
  PATIENT
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LabResultStatus {
  PENDING
  AVAILABLE
  FLAGGED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

// ── Subscription Tiers ───────────────────────────────────────────────────────
// Global — not tenant-scoped. Managed by Super Admin (CC-26).

model SubscriptionTier {
  id                String           @id @default(cuid())
  plan              SubscriptionPlan @unique
  name              String
  maxBranches       Int              // -1 = unlimited
  maxStaff          Int              // -1 = unlimited
  storageLimitBytes BigInt
  monthlyPriceUsd   Decimal          @db.Decimal(10, 2)
  createdAt         DateTime         @default(now())

  tenants Tenant[]

  @@map("subscription_tiers")
}

// ── Tenants ──────────────────────────────────────────────────────────────────
// The top-level isolation unit. One tenant = one subscribing clinic/org.
// tenant_id on all child tables references this.

model Tenant {
  id                 String            @id @default(uuid())
  name               String
  slug               String            @unique
  plan               SubscriptionPlan  @default(FREE)
  subscriptionTierId String?
  subscriptionTier   SubscriptionTier? @relation(fields: [subscriptionTierId], references: [id])
  storageLimitBytes  BigInt            @default(1073741824) // 1 GB default
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  users                User[]
  organizations        Organization[]
  branches             Branch[]
  staffAssignments     StaffAssignment[]
  invitations          Invitation[]
  patients             Patient[]
  appointments         Appointment[]
  labResults           LabResult[]
  professionals        Professional[]
  professionalSchedules ProfessionalSchedule[]
  timeOffs             TimeOff[]
  clinicHours          ClinicHours[]
  specialClosures      SpecialClosure[]
  invoices             Invoice[]
  invoiceLineItems     InvoiceLineItem[]

  @@map("tenants")
}

// ── Users ────────────────────────────────────────────────────────────────────
// All user types (staff + patients). Identity managed by Supabase Auth;
// supabaseUserId links this record to the Supabase user.

model User {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supabaseUserId String   @unique
  email          String?
  phone          String?  // used for SMS-registered patients
  role           Role     @default(PATIENT)
  firstName      String
  lastName       String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  staffAssignments           StaffAssignment[]
  sentInvitations            Invitation[]      @relation("InvitedBy")
  patient                    Patient?
  appointmentsAsProfessional Appointment[]     @relation("AppointmentProfessional")
  orderedLabResults          LabResult[]       @relation("LabResultOrderedBy")
  professional               Professional?

  @@index([tenantId])
  @@index([supabaseUserId])
  @@map("users")
}

// ── Organizations ────────────────────────────────────────────────────────────
// Clinic profile. One per tenant initially; structure supports future multi-org.

model Organization {
  id                       String   @id @default(uuid())
  tenantId                 String
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                     String
  address                  String?
  phone                    String?
  email                    String?
  logoUrl                  String?
  patientSelfUploadEnabled Boolean  @default(true)
  brandColor               String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  branches Branch[]

  @@index([tenantId])
  @@map("organizations")
}

// ── Branches ─────────────────────────────────────────────────────────────────
// Physical clinic locations under an organization.

model Branch {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  phone          String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  staffAssignments      StaffAssignment[]
  invitations           Invitation[]
  appointments          Appointment[]
  professionalSchedules ProfessionalSchedule[]
  clinicHours           ClinicHours[]
  specialClosures       SpecialClosure[]

  @@index([tenantId])
  @@index([organizationId])
  @@map("branches")
}

// ── Staff Assignments ────────────────────────────────────────────────────────
// Maps staff users to branches (many-to-many). A user may work at multiple branches.

model StaffAssignment {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@index([tenantId])
  @@index([userId])
  @@index([branchId])
  @@map("staff_assignments")
}

// ── Invitations ───────────────────────────────────────────────────────────────
// Pending email invitations for staff. Token is single-use and expires.

model Invitation {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String
  role        Role
  branchId    String?
  branch      Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])
  token       String    @unique @default(uuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([token])
  @@map("invitations")
}

// ── Patients ──────────────────────────────────────────────────────────────────
// Standalone patient profile. May be linked to a portal User account (PATIENT role).
// Allows registering walk-in patients who never use the portal.

model Patient {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?   @unique // linked portal account (optional)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName String
  lastName  String
  dob       DateTime?
  gender    String?
  bloodType String?
  phone     String?
  email     String?
  allergies String[]  @default([])
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  appointments Appointment[]
  labResults   LabResult[]
  invoices     Invoice[]

  @@index([tenantId])
  @@map("patients")
}

// ── Appointments ──────────────────────────────────────────────────────────────
// A patient appointment with a professional at a branch.
// One patient may have many appointments across different professionals.

model Appointment {
  id             String            @id @default(uuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId      String
  patient        Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professionalId String
  professional   User              @relation("AppointmentProfessional", fields: [professionalId], references: [id])
  branchId       String
  branch         Branch            @relation(fields: [branchId], references: [id])
  scheduledAt    DateTime
  durationMins   Int               @default(30)
  type           String
  status         AppointmentStatus @default(BOOKED)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  labResults LabResult[]
  invoices   Invoice[]

  @@index([tenantId])
  @@index([patientId])
  @@index([professionalId])
  @@index([scheduledAt])
  @@map("appointments")
}

// ── Lab Results ───────────────────────────────────────────────────────────────
// A lab result is always linked to a patient.
// Optionally linked to the appointment that generated it.

model LabResult {
  id            String          @id @default(uuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  orderedById   String?
  orderedBy     User?           @relation("LabResultOrderedBy", fields: [orderedById], references: [id], onDelete: SetNull)
  testName      String
  result        String?
  resultFileUrl String?
  status        LabResultStatus @default(PENDING)
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId])
  @@index([patientId])
  @@index([appointmentId])
  @@map("lab_results")
}

// ── Professionals ─────────────────────────────────────────────────────────────
// Extended profile for staff who take appointments (doctors, nurses, etc.)

model Professional {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization   String
  bio              String?
  slotDurationMins Int      @default(30)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  schedules ProfessionalSchedule[]
  timeOffs  TimeOff[]

  @@index([tenantId])
  @@map("professionals")
}

// ── Professional Schedules ────────────────────────────────────────────────────
// Weekly availability per professional per branch.
// weekday: 0 = Monday … 6 = Sunday

model ProfessionalSchedule {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  weekday        Int          // 0 = Monday … 6 = Sunday
  startTime      String       // 'HH:mm'
  endTime        String       // 'HH:mm'

  @@unique([professionalId, branchId, weekday])
  @@index([tenantId])
  @@index([professionalId])
  @@map("professional_schedules")
}

// ── Time Off ──────────────────────────────────────────────────────────────────
// Leave / time-off periods for a professional.

model TimeOff {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime
  reason         String?
  createdAt      DateTime     @default(now())

  @@index([tenantId])
  @@index([professionalId])
  @@map("time_offs")
}

// ── Clinic Hours ──────────────────────────────────────────────────────────────
// Operating hours per branch per weekday.
// weekday: 0 = Monday … 6 = Sunday

model ClinicHours {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  weekday   Int      // 0 = Monday … 6 = Sunday
  openTime  String   // 'HH:mm'
  closeTime String   // 'HH:mm'
  isClosed  Boolean  @default(false)

  @@unique([branchId, weekday])
  @@index([tenantId])
  @@map("clinic_hours")
}

// ── Special Closures ──────────────────────────────────────────────────────────
// One-off closures: holidays, emergency shutdowns, etc.

model SpecialClosure {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([branchId])
  @@map("special_closures")
}

// ── Invoices ──────────────────────────────────────────────────────────────────
// One invoice per patient visit. Status lifecycle: DRAFT → SENT → PAID (or OVERDUE).

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

model Invoice {
  id               String        @id @default(uuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId        String
  patient          Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId    String?
  appointment      Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  invoiceNumber    String
  status           InvoiceStatus @default(DRAFT)
  totalAmountCents Int           @default(0)
  issuedAt         DateTime      @default(now())
  dueAt            DateTime
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lineItems InvoiceLineItem[]

  @@index([tenantId])
  @@index([patientId])
  @@index([appointmentId])
  @@map("invoices")
}

// ── Invoice Line Items ────────────────────────────────────────────────────────

model InvoiceLineItem {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description    String
  quantity       Int      @default(1)
  unitPriceCents Int
  totalCents     Int

  @@index([tenantId])
  @@index([invoiceId])
  @@map("invoice_line_items")
}

// ── Tenant Requests (CC-119) ──────────────────────────────────────────────────
// Sign-up requests submitted by medical groups before provisioning.

enum TenantRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TenantRequest {
  id           String              @id @default(uuid())
  orgName      String
  contactName  String
  contactEmail String
  contactPhone String?
  planRequested SubscriptionPlan   @default(PRO)
  notes        String?
  status       TenantRequestStatus @default(PENDING)
  reviewedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  provisioningLogs ProvisioningLog[]

  @@index([status])
  @@map("tenant_requests")
}

// ── Provisioning Logs (CC-122) ────────────────────────────────────────────────
// Tracks the 4-step provisioning pipeline per approved tenant request.

enum ProvisioningStep {
  DB_RECORD
  ROLES_SEED
  STORAGE_SETUP
  WELCOME_EMAIL
}

enum ProvisioningStepStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model ProvisioningLog {
  id              String                 @id @default(uuid())
  tenantRequestId String
  tenantRequest   TenantRequest          @relation(fields: [tenantRequestId], references: [id], onDelete: Cascade)
  provisionedTenantId String?             // set once DB_RECORD step completes
  step            ProvisioningStep
  status          ProvisioningStepStatus @default(PENDING)
  errorMessage    String?
  completedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([tenantRequestId, step])
  @@index([tenantRequestId])
  @@map("provisioning_logs")
}

// ── Global Master Data (CC-121) ───────────────────────────────────────────────
// Platform-wide reference data managed by Super Admin.
// Not tenant-scoped — shared across all tenants.

model Specialty {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("specialties")
}

model AppointmentType {
  id            String   @id @default(uuid())
  name          String   @unique
  defaultMinutes Int     @default(30)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("appointment_types")
}

model ServiceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_categories")
}

// ── Platform Updates (CC-126) ─────────────────────────────────────────────────
// Platform-wide announcements, feature flags, and maintenance windows.
// Managed by Super Admin.

enum AnnouncementSeverity {
  INFO
  WARNING
  CRITICAL
}

model Announcement {
  id          String               @id @default(uuid())
  title       String
  body        String
  severity    AnnouncementSeverity @default(INFO)
  isArchived  Boolean              @default(false)
  publishedAt DateTime             @default(now())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([isArchived])
  @@map("announcements")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  enabledFor  String[] @default([]) // plan names: e.g. ["PRO","ENTERPRISE"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

model MaintenanceWindow {
  id          String    @id @default(uuid())
  title       String
  startsAt    DateTime
  endsAt      DateTime
  isCancelled Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startsAt])
  @@map("maintenance_windows")
}
