# ClinicCore 2.0 — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/cliniccore"

# ============================================================
# SUPABASE AUTH
# ============================================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
JWT_SECRET="your-supabase-jwt-secret"

# ============================================================
# AWS S3 — File Storage
# ============================================================
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="cliniccore-files"

# ============================================================
# MALWARE SCANNING
# ============================================================
# e.g. ClamAV or third-party scanning service
MALWARE_SCAN_API_URL="https://your-scan-service/scan"
MALWARE_SCAN_API_KEY="your-scan-api-key"

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"
API_BASE_URL="http://localhost:3001"

# ============================================================
# SMS (for patient OTP registration)
# ============================================================
# e.g. Twilio or AWS SNS
SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# ============================================================
# SLACK NOTIFICATIONS (Phase 22)
# ============================================================
# Developer channel — task activity, PRs, regressions, deploys, prod issues
SLACK_WEBHOOK_DEV="https://hooks.slack.com/services/YOUR/DEV/WEBHOOK"
# Product Owner channel — staging sign-off, prod live, release notes, bug escalations
SLACK_WEBHOOK_PO="https://hooks.slack.com/services/YOUR/PO/WEBHOOK"
# Handle to ping on regressions and production failures
SLACK_ONCALL="@your-oncall-handle"

# Slack Bot Token — required for READING channel responses (outbound webhooks above are write-only)
# Create a Slack app at https://api.slack.com/apps → OAuth & Permissions
# Scopes needed: channels:history, channels:read, groups:history (for private channels)
SLACK_BOT_TOKEN="xoxb-your-bot-token"
# Channel IDs (not names) — right-click a channel in Slack → Copy Link → ID is the last segment
SLACK_DEV_CHANNEL_ID="C0XXXXXXXXX"
SLACK_PO_CHANNEL_ID="C0YYYYYYYYY"
