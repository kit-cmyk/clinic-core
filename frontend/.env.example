# ClinicCore 2.0 — Frontend Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control

# ── API ──────────────────────────────────────────────────────────────────────
# Backend API base URL
VITE_API_URL="http://localhost:3001"

# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL="https://your-project.supabase.co"
# Supabase anon/public key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Bucket name — must match SUPABASE_STORAGE_BUCKET in backend .env
VITE_SUPABASE_STORAGE_BUCKET="cliniccore-files"
